# Admin authentication
ADMIN_PASSWORD=your-secure-admin-password-here

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/leaderboard_db?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379

# JWT signing secret (for game tokens)
JWT_SECRET=your-jwt-secret-key-here

# Server
SERVER_PORT=8080

# Logging
# verbose — all logs including per-request access log (useful for development)
# info    — startup, shutdown, and error events only (default)
# warn    — warnings and errors only
# error   — errors only (recommended for high-throughput production)
LOG_LEVEL=info
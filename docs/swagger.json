{
    "swagger": "2.0",
    "info": {
        "description": "Production-ready leaderboard backend for game centers.\nReal-time rankings backed by Redis sorted sets with JWT game authentication.",
        "title": "Leaderboard Service API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/admin/games": {
            "post": {
                "description": "Creates a new game and returns a signed JWT. Use the token in the Authorization header for all leaderboard endpoints.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Admin"
                ],
                "summary": "Register a game",
                "parameters": [
                    {
                        "description": "Game registration details",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.RegisterGameRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "game created",
                        "schema": {
                            "$ref": "#/definitions/api.GameResponse"
                        }
                    },
                    "400": {
                        "description": "invalid request or missing game_name",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "wrong admin password",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/admin/games/{id}": {
            "patch": {
                "description": "Updates name and/or description for a game. game_name is optional; omit to keep the current value.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Admin"
                ],
                "summary": "Update game details",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Game UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Fields to update",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.EditGameRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "game updated",
                        "schema": {
                            "$ref": "#/definitions/api.GameResponse"
                        }
                    },
                    "400": {
                        "description": "invalid game id",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "wrong admin password",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "game not found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/admin/games/{id}/refresh-token": {
            "post": {
                "description": "Revokes the current JWT and issues a new one. Any client using the old token is rejected immediately.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Admin"
                ],
                "summary": "Refresh game token",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Game UUID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Admin credentials",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.RefreshTokenRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "new token issued",
                        "schema": {
                            "$ref": "#/definitions/api.GameResponse"
                        }
                    },
                    "400": {
                        "description": "invalid game id",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "wrong admin password",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "game not found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/health/live": {
            "get": {
                "description": "Always returns 200. Used by Kubernetes to confirm the process is running.",
                "tags": [
                    "Health"
                ],
                "summary": "Liveness probe",
                "responses": {
                    "200": {
                        "description": "alive"
                    }
                }
            }
        },
        "/health/ready": {
            "get": {
                "description": "Pings PostgreSQL and Redis. Returns 503 if either dependency is unreachable.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Readiness probe",
                "responses": {
                    "200": {
                        "description": "all dependencies healthy",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "503": {
                        "description": "one or more dependencies unreachable",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/leaderboards": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Creates a new leaderboard scoped to the authenticated game. unique_name must be unique within the game.\nType options: record (personal best), additive (cumulative total), onetime (first submission only).\nSet interval_seconds to 0 for all-time, 86400 for daily, 604800 for weekly.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Leaderboards"
                ],
                "summary": "Create a leaderboard",
                "parameters": [
                    {
                        "description": "Leaderboard configuration",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.CreateLeaderboardRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "leaderboard created",
                        "schema": {
                            "$ref": "#/definitions/domain.Leaderboard"
                        }
                    },
                    "400": {
                        "description": "missing fields or invalid type",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "invalid or missing token",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "leaderboard name already exists for this game",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/leaderboards/{name}/rankings": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Returns paginated rankings for a leaderboard. Optionally fetches the requesting user's rank via user_id.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Leaderboards"
                ],
                "summary": "Get rankings",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Leaderboard unique name",
                        "name": "name",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Page number (default: 1)",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Results per page (default: 20)",
                        "name": "page_size",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Include this user's rank and score in user_entry",
                        "name": "user_id",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Time bucket (-1 = current period, 0+ = historical)",
                        "name": "duration_index",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/api.GetRankingsResponseBody"
                        }
                    },
                    "401": {
                        "description": "invalid or missing token",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "leaderboard not found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/leaderboards/{name}/scores": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Records a score for a user. Behavior depends on leaderboard type: record keeps the personal best, additive accumulates all submissions, onetime ignores submissions after the first.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Leaderboards"
                ],
                "summary": "Submit a score",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Leaderboard unique name",
                        "name": "name",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Score submission",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/api.SubmitScoreRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "score recorded"
                    },
                    "400": {
                        "description": "missing user_id",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "401": {
                        "description": "invalid or missing token",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "leaderboard not found",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/api.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "api.CreateLeaderboardRequest": {
            "type": "object",
            "properties": {
                "description": {
                    "type": "string"
                },
                "interval_seconds": {
                    "type": "integer"
                },
                "type": {
                    "type": "string"
                },
                "unique_name": {
                    "type": "string"
                }
            }
        },
        "api.EditGameRequest": {
            "type": "object",
            "properties": {
                "admin_password": {
                    "type": "string"
                },
                "game_desc": {
                    "type": "string"
                },
                "game_name": {
                    "type": "string"
                }
            }
        },
        "api.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                }
            }
        },
        "api.GameResponse": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "token": {
                    "description": "Only in register/refresh responses",
                    "type": "string"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        },
        "api.GetRankingsResponseBody": {
            "type": "object",
            "properties": {
                "page": {
                    "type": "integer"
                },
                "page_size": {
                    "type": "integer"
                },
                "rankings": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/domain.ScoreObject"
                    }
                },
                "total": {
                    "type": "integer"
                },
                "user_entry": {
                    "$ref": "#/definitions/domain.ScoreObject"
                }
            }
        },
        "api.RefreshTokenRequest": {
            "type": "object",
            "properties": {
                "admin_password": {
                    "type": "string"
                },
                "game_id": {
                    "type": "string"
                }
            }
        },
        "api.RegisterGameRequest": {
            "type": "object",
            "properties": {
                "admin_password": {
                    "type": "string"
                },
                "game_desc": {
                    "type": "string"
                },
                "game_name": {
                    "type": "string"
                }
            }
        },
        "api.SubmitScoreRequest": {
            "type": "object",
            "properties": {
                "score": {
                    "type": "integer"
                },
                "user_id": {
                    "type": "string"
                }
            }
        },
        "domain.Leaderboard": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "game_id": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "interval_seconds": {
                    "type": "integer"
                },
                "type": {
                    "$ref": "#/definitions/domain.LeaderboardType"
                },
                "unique_name": {
                    "type": "string"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        },
        "domain.LeaderboardType": {
            "type": "string",
            "enum": [
                "record",
                "additive",
                "onetime"
            ],
            "x-enum-varnames": [
                "Record",
                "Additive",
                "OneTime"
            ]
        },
        "domain.ScoreObject": {
            "type": "object",
            "properties": {
                "rank": {
                    "type": "integer"
                },
                "score": {
                    "type": "integer"
                },
                "user_id": {
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "Enter your game JWT as: Bearer {token}",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}